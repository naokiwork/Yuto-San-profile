{
  "name": "profile-webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && rm -rf out && mkdir -p out/_next/static && cp -r .next/static/* out/_next/static/ && cp -r public/* out/ && cp -r .next/server/app/*.html out/",
    "start": "next start",
    "deploy": "node scripts/deploy-with-retry.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "next lint",
    "build:ci": "npm run typecheck && npm run lint && next build",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
